# --- Aiven PostgreSQL Configuration ---
# Replace with your actual URI from the Aiven console
DATABASE_URL=postgres://avnadmin:password@hostname:port/defaultdb?sslmode=require

# --- Server Configuration ---
PORT=3000

# --- Firebase Admin Configuration ---
# Option 1: Path to your JSON file (local development)
# FIREBASE_CONFIG_PATH=./serviceAccountKey.json

# Option 2: Base64 encoded JSON string (recommended for clouds like Aiven/Render)
# You can generate this by running: base64 -w 0 serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT=your_base64_encoded_json_here
